# Required
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
ANTHROPIC_API_KEY=sk-ant-...

# Optional: comma-separated Telegram user IDs to restrict access (empty = open)
ALLOWED_USER_IDS=

# Optional: Claude model to use (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: how many messages to keep in conversation history (default: 40)
MAX_HISTORY_MESSAGES=40

# Optional: directory for storing user profiles and history
DATA_DIR=
